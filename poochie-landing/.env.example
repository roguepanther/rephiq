# Copy to `.env.local`. Never commit real secrets or `.env.local`.

# --- Safe to expose in the browser (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# --- Server-only (never use NEXT_PUBLIC_ for these) ---
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# WAITLIST_API_SECRET=
